generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  role          String?
  bio           String?
  skills        String[]  @default([])
  domains       Domain[]
  works         Work[]
  testimonials  Testimonial[]
  experiences   Experience[]
  pageViews     PageView[]
  tools         String?
  resumeLink    String?
  contactEmail  String?
  socials       String?
  phoneNumber   String?
  background      String?
  backgroundBlur  Int?     @default(0)
  backgroundMotion Boolean? @default(false)
  customCursor     String?  @default("default")
  welcomeEmailSent Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model Experience {
  id               String   @id @default(cuid())
  company          String
  designation      String?
  fromDate         String?
  toDate           String?
  currentlyWorking Boolean  @default(false)
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
}

model Work {
  id          String   @id @default(cuid())
  title       String
  description String?
  image       String?
  client      String?
  role        String?
  industry    String?
  platform    String?
  content     String?   @db.Text
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String?
  description String?
  image       String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Domain {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}

model PageView {
  id        String   @id @default(cuid())
  userId    String
  viewDate  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
